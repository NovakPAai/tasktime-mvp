# Pipeline Service Environment Variables
PORT=3100
NODE_ENV=development
DATABASE_URL=postgresql://pipeline:pipeline@localhost:5433/pipeline
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=pl:
REDIS_CACHE_TTL_SECONDS=30

# Auth: shared secret with Flow Universe backend
PIPELINE_API_KEY=dev-pipeline-key-change-in-prod

# GitHub integration
GITHUB_TOKEN=ghp_xxx
GITHUB_REPOS=jackrescuer-gif/tasktime-mvp
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Polling interval in seconds (min 30, default 60)
SYNC_INTERVAL_SEC=60

# Flow Universe API (for issue/release resolution, optional)
FU_API_URL=http://localhost:3000
FU_API_KEY=dev-fu-key
