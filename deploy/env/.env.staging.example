# Docker image tags (filled in by CI via IMAGE_TAG argument)
IMAGE_TAG=main
BACKEND_IMAGE=ghcr.io/jackrescuer-gif/tasktime-backend
WEB_IMAGE=ghcr.io/jackrescuer-gif/tasktime-web
PIPELINE_IMAGE=ghcr.io/jackrescuer-gif/tasktime-pipeline

# Main app DB credentials (must match backend.staging.env DATABASE_URL)
POSTGRES_DB=tasktime_staging
POSTGRES_USER=tasktime
POSTGRES_PASSWORD=CHANGE_ME

# Pipeline service DB credentials (must match pipeline.staging.env DATABASE_URL)
PIPELINE_POSTGRES_DB=pipeline
PIPELINE_POSTGRES_USER=pipeline
PIPELINE_POSTGRES_PASSWORD=CHANGE_ME

# Nginx port
WEB_HTTP_PORT=8080

# Required by db:sync:prod-to-dev — points to a read-only production/staging source.
# Never set this to the same host as DATABASE_URL.
SOURCE_DATABASE_URL=postgresql://readonly-user:CHANGE_ME@prod-host:5432/tasktime?schema=public
