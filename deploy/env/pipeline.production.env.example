DATABASE_URL=postgresql://pipeline:CHANGE_ME@pipeline-postgres:5432/pipeline
PORT=3100
NODE_ENV=production

# GitHub fine-grained PAT (Settings → Developer settings → Fine-grained tokens)
# Required permissions: Contents (read), Pull requests (read), Actions (read)
# Scope: only this repository
APP_GITHUB_REPOS=NovakPAai/tasktime-mvp
GITHUB_TOKEN=ghp_CHANGE_ME

# Secret key protecting /api/github/* and /api/batches/* routes
PIPELINE_API_KEY=CHANGE_ME_USE_openssl_rand_hex_32
