{
  "name": "tasktime-frontend",
  "version": "1.0.0",
  "description": "TaskTime MVP frontend - Russian fintech task management system",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "tokens:sync": "node scripts/sync-tokens.js",
    "build": "npm run tokens:sync && tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src/ --ext .ts,.tsx",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@lezer/highlight": "^1.2.3",
    "@types/react-window": "^1.8.8",
    "@xyflow/react": "^12.10.2",
    "antd": "^5.24.2",
    "axios": "^1.7.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^7.3.0",
    "react-window": "^2.2.7",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "web-vitals": "^4.2.4",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@chromatic-com/storybook": "^5.0.2",
    "@playwright/test": "^1.50.0",
    "@storybook/addon-a11y": "^10.3.1",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/addon-onboarding": "^10.3.1",
    "@storybook/addon-vitest": "^10.3.1",
    "@storybook/react-vite": "^10.3.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "chromatic": "^15.3.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.3.1",
    "playwright": "^1.50.0",
    "storybook": "^10.3.1",
    "typescript": "^5.7.3",
    "vite": "^6.2.2",
    "vitest": "^4.1.0"
  }
}
