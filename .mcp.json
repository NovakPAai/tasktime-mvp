{
  "mcpServers": {
    "flow-universe": {
      "command": "npm",
      "args": ["run", "mcp"],
      "cwd": "backend",
      "env": {
        "MCP_ENV": "development",
        "AI_HOURLY_RATE": "50"
      }
    },
    "flow-universe-staging": {
      "type": "streamable-http",
      "url": "http://5.129.242.171:3002/mcp",
      "headers": {
        "Authorization": "Bearer REPLACE_WITH_MCP_SERVICE_TOKEN"
      }
    },
    "flow-universe-prod": {
      "type": "streamable-http",
      "url": "http://72.56.7.218:3002/mcp",
      "headers": {
        "Authorization": "Bearer REPLACE_WITH_MCP_SERVICE_TOKEN"
      }
    }
  }
}
